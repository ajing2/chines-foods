---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

type Props = CollectionEntry<'blog'>['data'];

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  category,
  cookTime,
  prepTime,
  servings,
  difficulty,
  lang = 'zh',
  translations,
} = Astro.props;
---

<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} image={heroImage} />
    <style>
      main {
        width: calc(100% - 2em);
        max-width: 100%;
        margin: 0;
      }
      .hero-image {
        width: 100%;
      }
      .hero-image img {
        display: block;
        margin: 0 auto;
        border-radius: 12px;
        box-shadow: var(--box-shadow);
      }
      .hero-image.hidden {
        display: none;
      }
      .prose {
        width: 720px;
        max-width: calc(100% - 2em);
        margin: auto;
        padding: 1em;
        color: rgb(var(--gray-dark));
      }
      .title {
        margin-bottom: 1em;
        padding: 1em 0;
        text-align: center;
        line-height: 1;
      }
      .title h1 {
        margin: 0 0 0.5em 0;
      }
      .date {
        margin-bottom: 0.5em;
        color: rgb(var(--gray));
      }
      .last-updated-on {
        font-style: italic;
      }
      /* 与模板保持一致：日期在左，语言切换器在右 */
      .article-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1rem;
      }
      /* 食谱专属：菜系/难度徽章行 */
      .recipe-badges {
        display: flex;
        justify-content: center;
        gap: 0.6em;
        flex-wrap: wrap;
        margin-bottom: 0.8em;
      }
      .category-badge {
        background: var(--accent);
        color: white;
        padding: 0.2em 0.8em;
        border-radius: 20px;
        font-size: 0.82em;
        font-weight: 600;
      }
      .difficulty-badge {
        border: 1px solid rgb(var(--gray-light));
        padding: 0.2em 0.8em;
        border-radius: 20px;
        font-size: 0.82em;
        color: rgb(var(--gray));
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <article>
        {heroImage && (
          <div class="hero-image" id="hero-wrap">
            <img
              width={1020}
              height={510}
              src={heroImage}
              alt=""
              onerror="this.parentElement.classList.add('hidden')"
            />
          </div>
        )}
        <div class="prose">
          <div class="title">
            <!-- 与模板完全一致的 article-meta 布局：日期左，语言切换器右 -->
            <div class="article-meta">
              <div class="date">
                <FormattedDate date={pubDate} />
                {updatedDate && (
                  <div class="last-updated-on">
                    <span data-i18n-key="updatedAt"></span> <FormattedDate date={updatedDate} />
                  </div>
                )}
              </div>
              <LanguageSwitcher currentLang={lang} translations={translations} />
            </div>
            <!-- 食谱专属：菜系 + 难度徽章 -->
            <div class="recipe-badges">
              <span class="category-badge" data-i18n-key="category" data-raw-value={category}>{category}</span>
              <span class="difficulty-badge"><span data-i18n-key="difficultyLabel"></span><span data-i18n-key="difficulty" data-raw-value={difficulty}></span></span>
            </div>
            <h1>{title}</h1>
            <hr />
          </div>

          <!-- 食谱信息卡片（准备/烹饪时间、份量） -->
          {(cookTime || prepTime || servings) && (
            <div class="recipe-meta">
              {prepTime && (
                <div class="recipe-meta-item">
                  <span class="label" data-i18n-key="prepTime"></span>
                  <span class="value">{prepTime}</span>
                </div>
              )}
              {cookTime && (
                <div class="recipe-meta-item">
                  <span class="label" data-i18n-key="cookTime"></span>
                  <span class="value">{cookTime}</span>
                </div>
              )}
              {servings && (
                <div class="recipe-meta-item">
                  <span class="label" data-i18n-key="servings"></span>
                  <span class="value">{servings}</span>
                </div>
              )}
            </div>
          )}

          <slot />
        </div>
      </article>
    </main>
    <Footer />

    <!-- i18n for recipe labels + auto-redirect -->
    <script is:inline define:vars={{ lang }}>
      (function() {
        var SUPPORTED = ['zh', 'en', 'ja', 'fr', 'de'];
        var currentLang = lang;

        // i18n strings for recipe detail page
        var RECIPE_I18N = {
          zh: { prepTime: '准备时间', cookTime: '烹饪时间', servings: '份量', difficultyLabel: '难度：', updatedAt: '更新于',
                category: { '川菜': '川菜', '粤菜': '粤菜', '鲁菜': '鲁菜', '湘菜': '湘菜', '苏菜': '苏菜', '闽菜': '闽菜', '浙菜': '浙菜', '徽菜': '徽菜' },
                difficulty: { '简单': '简单', '中等': '中等', '困难': '困难' }
          },
          en: { prepTime: 'Prep Time', cookTime: 'Cook Time', servings: 'Servings', difficultyLabel: 'Difficulty: ', updatedAt: 'Updated on',
                category: { '川菜': 'Sichuan', '粤菜': 'Cantonese', '鲁菜': 'Shandong', '湘菜': 'Hunan', '苏菜': 'Jiangsu', '闽菜': 'Fujian', '浙菜': 'Zhejiang', '徽菜': 'Anhui' },
                difficulty: { '简单': 'Easy', '中等': 'Medium', '困难': 'Hard' }
          },
          ja: { prepTime: '下準備', cookTime: '調理時間', servings: '分量', difficultyLabel: '難易度：', updatedAt: '更新日',
                category: { '川菜': '四川料理', '粤菜': '広東料理', '鲁菜': '山東料理', '湘菜': '湖南料理', '苏菜': '江蘇料理', '闽菜': '福建料理', '浙菜': '浙江料理', '徽菜': '安徽料理' },
                difficulty: { '简单': '簡単', '中等': '普通', '困难': '難しい' }
          },
          fr: { prepTime: 'Préparation', cookTime: 'Cuisson', servings: 'Portions', difficultyLabel: 'Difficulté : ', updatedAt: 'Mis à jour le',
                category: { '川菜': 'Sichuan', '粤菜': 'Cantonais', '鲁菜': 'Shandong', '湘菜': 'Hunan', '苏菜': 'Jiangsu', '闽菜': 'Fujian', '浙菜': 'Zhejiang', '徽菜': 'Anhui' },
                difficulty: { '简单': 'Facile', '中等': 'Moyen', '困难': 'Difficile' }
          },
          de: { prepTime: 'Vorbereitung', cookTime: 'Kochzeit', servings: 'Portionen', difficultyLabel: 'Schwierigkeit: ', updatedAt: 'Aktualisiert am',
                category: { '川菜': 'Sichuan', '粤菜': 'Kantonesisch', '鲁菜': 'Shandong', '湘菜': 'Hunan', '苏菜': 'Jiangsu', '闽菜': 'Fujian', '浙菜': 'Zhejiang', '徽菜': 'Anhui' },
                difficulty: { '简单': 'Einfach', '中等': 'Mittel', '困难': 'Schwer' }
          }
        };

        function applyRecipeI18n(pageLang) {
          var strings = RECIPE_I18N[pageLang];
          if (!strings) return;

          // Simple text labels
          var els = document.querySelectorAll('[data-i18n-key]');
          for (var i = 0; i < els.length; i++) {
            var key = els[i].getAttribute('data-i18n-key');
            var rawValue = els[i].getAttribute('data-raw-value');

            if (key === 'category' && rawValue && strings.category) {
              els[i].textContent = strings.category[rawValue] || rawValue;
            } else if (key === 'difficulty' && rawValue && strings.difficulty) {
              els[i].textContent = strings.difficulty[rawValue] || rawValue;
            } else if (strings[key] && typeof strings[key] === 'string') {
              els[i].textContent = strings[key];
            }
          }
        }

        // Apply i18n based on the article's own lang
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function() { applyRecipeI18n(currentLang); });
        } else {
          applyRecipeI18n(currentLang);
        }

        // Auto-redirect to correct language version if global lang differs
        try {
          var stored = localStorage.getItem('site-lang');
          if (stored && SUPPORTED.indexOf(stored) !== -1 && stored !== currentLang) {
            var path = window.location.pathname;
            var slug = path.replace(/^\/blog\//, '').replace(/\/$/, '');
            var baseParts = slug.split('-');
            var lastPart = baseParts[baseParts.length - 1];
            if (SUPPORTED.indexOf(lastPart) !== -1) {
              baseParts[baseParts.length - 1] = stored;
              var newSlug = baseParts.join('-');
              window.location.replace('/blog/' + newSlug + '/');
            }
          }
        } catch(e) {}
      })();
    </script>
  </body>
</html>
