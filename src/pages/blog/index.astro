---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';

// 获取所有文章（所有语言），客户端根据 localStorage 过滤
const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`食谱列表 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      .page-title {
        font-size: 2em;
        margin-bottom: 0.2em;
      }
      .page-subtitle {
        color: rgb(var(--gray));
        margin-bottom: 2em;
      }
      .posts-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      .post-item a {
        display: flex;
        gap: 1.2em;
        text-decoration: none;
        border-radius: 10px;
        border: 1px solid rgb(var(--gray-light));
        overflow: hidden;
        transition: box-shadow 0.2s;
      }
      .post-item a:hover {
        box-shadow: var(--box-shadow);
        text-decoration: none;
      }
      .post-item img {
        width: 180px;
        height: 120px;
        object-fit: cover;
        flex-shrink: 0;
        border-radius: 0;
      }
      .post-item .item-body {
        padding: 1em 1em 1em 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
      .item-meta {
        display: flex;
        gap: 0.6em;
        align-items: center;
        margin-bottom: 0.4em;
      }
      .category-badge {
        background: var(--accent);
        color: white;
        padding: 0.15em 0.6em;
        border-radius: 20px;
        font-size: 0.78em;
        font-weight: 600;
      }
      .difficulty-badge {
        border: 1px solid rgb(var(--gray-light));
        padding: 0.15em 0.6em;
        border-radius: 20px;
        font-size: 0.78em;
        color: rgb(var(--gray));
      }
      .lang-badge {
        background: rgba(192, 57, 43, 0.1);
        color: var(--accent);
        padding: 0.15em 0.6em;
        border-radius: 20px;
        font-size: 0.78em;
        font-weight: 600;
      }
      .post-item h2 {
        font-size: 1.15em;
        margin: 0 0 0.3em;
        color: rgb(var(--black));
      }
      .post-item p {
        font-size: 0.9em;
        color: rgb(var(--gray));
        margin: 0 0 0.4em;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .post-date {
        font-size: 0.82em;
        color: rgb(var(--gray));
      }
      .post-item[data-hidden="true"] {
        display: none;
      }
      @media (max-width: 600px) {
        .post-item img { width: 110px; height: 90px; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1 class="page-title" id="blog-title">所有食谱</h1>
      <p class="page-subtitle" id="blog-subtitle">共 {allPosts.length} 道菜</p>
      <ul class="posts-list" id="posts-list">
        {allPosts.map((post) => (
          <li class="post-item" data-post-lang={post.data.lang || 'zh'} data-category={post.data.category} data-difficulty={post.data.difficulty}>
            <a href={`/blog/${post.id}/`}>
              {post.data.heroImage && (
                <img src={post.data.heroImage} alt={post.data.title} />
              )}
              <div class="item-body">
                <div class="item-meta">
                  <span class="category-badge" data-translate="category">{post.data.category}</span>
                  <span class="difficulty-badge" data-translate="difficulty">{post.data.difficulty}</span>
                  <span class="lang-badge">{
                    (post.data.lang || 'zh') === 'zh' ? '\u{1F1E8}\u{1F1F3} \u4E2D\u6587' :
                    (post.data.lang || 'zh') === 'en' ? '\u{1F1FA}\u{1F1F8} EN' :
                    (post.data.lang || 'zh') === 'ja' ? '\u{1F1EF}\u{1F1F5} JA' :
                    (post.data.lang || 'zh') === 'fr' ? '\u{1F1EB}\u{1F1F7} FR' :
                    '\u{1F1E9}\u{1F1EA} DE'
                  }</span>
                </div>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                <span class="post-date">
                  <FormattedDate date={post.data.pubDate} />
                  {post.data.cookTime && ` \u00B7 ${post.data.cookTime}`}
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </main>
    <Footer />

    <script is:inline>
    (function() {
      var BLOG_STRINGS = {
        zh: { title: '\u6240\u6709\u98DF\u8C31', subtitle: function(n) { return '\u5171 ' + n + ' \u9053\u83DC'; } },
        en: { title: 'All Recipes', subtitle: function(n) { return n + ' recipes'; } },
        ja: { title: '\u5168\u30EC\u30B7\u30D4', subtitle: function(n) { return '\u5168' + n + '\u54C1'; } },
        fr: { title: 'Toutes les Recettes', subtitle: function(n) { return n + ' recettes'; } },
        de: { title: 'Alle Rezepte', subtitle: function(n) { return n + ' Rezepte'; } }
      };

      var CATEGORY_I18N = {
        zh: { '\u5DDD\u83DC': '\u5DDD\u83DC', '\u7CA4\u83DC': '\u7CA4\u83DC', '\u9C81\u83DC': '\u9C81\u83DC', '\u6E58\u83DC': '\u6E58\u83DC', '\u82CF\u83DC': '\u82CF\u83DC', '\u95FD\u83DC': '\u95FD\u83DC', '\u6D59\u83DC': '\u6D59\u83DC', '\u5FBD\u83DC': '\u5FBD\u83DC' },
        en: { '\u5DDD\u83DC': 'Sichuan', '\u7CA4\u83DC': 'Cantonese', '\u9C81\u83DC': 'Shandong', '\u6E58\u83DC': 'Hunan', '\u82CF\u83DC': 'Jiangsu', '\u95FD\u83DC': 'Fujian', '\u6D59\u83DC': 'Zhejiang', '\u5FBD\u83DC': 'Anhui' },
        ja: { '\u5DDD\u83DC': '\u56DB\u5DDD\u6599\u7406', '\u7CA4\u83DC': '\u5E83\u6771\u6599\u7406', '\u9C81\u83DC': '\u5C71\u6771\u6599\u7406', '\u6E58\u83DC': '\u6E56\u5357\u6599\u7406', '\u82CF\u83DC': '\u6C5F\u8607\u6599\u7406', '\u95FD\u83DC': '\u798F\u5EFA\u6599\u7406', '\u6D59\u83DC': '\u6D59\u6C5F\u6599\u7406', '\u5FBD\u83DC': '\u5B89\u5FBD\u6599\u7406' },
        fr: { '\u5DDD\u83DC': 'Sichuan', '\u7CA4\u83DC': 'Cantonais', '\u9C81\u83DC': 'Shandong', '\u6E58\u83DC': 'Hunan', '\u82CF\u83DC': 'Jiangsu', '\u95FD\u83DC': 'Fujian', '\u6D59\u83DC': 'Zhejiang', '\u5FBD\u83DC': 'Anhui' },
        de: { '\u5DDD\u83DC': 'Sichuan', '\u7CA4\u83DC': 'Kantonesisch', '\u9C81\u83DC': 'Shandong', '\u6E58\u83DC': 'Hunan', '\u82CF\u83DC': 'Jiangsu', '\u95FD\u83DC': 'Fujian', '\u6D59\u83DC': 'Zhejiang', '\u5FBD\u83DC': 'Anhui' }
      };

      var DIFFICULTY_I18N = {
        zh: { '\u7B80\u5355': '\u7B80\u5355', '\u4E2D\u7B49': '\u4E2D\u7B49', '\u56F0\u96BE': '\u56F0\u96BE' },
        en: { '\u7B80\u5355': 'Easy', '\u4E2D\u7B49': 'Medium', '\u56F0\u96BE': 'Hard' },
        ja: { '\u7B80\u5355': '\u7C21\u5358', '\u4E2D\u7B49': '\u666E\u901A', '\u56F0\u96BE': '\u96E3\u3057\u3044' },
        fr: { '\u7B80\u5355': 'Facile', '\u4E2D\u7B49': 'Moyen', '\u56F0\u96BE': 'Difficile' },
        de: { '\u7B80\u5355': 'Einfach', '\u4E2D\u7B49': 'Mittel', '\u56F0\u96BE': 'Schwer' }
      };

      var SUPPORTED = ['zh', 'en', 'ja', 'fr', 'de'];

      function getLang() {
        try {
          var stored = localStorage.getItem('site-lang');
          if (stored && SUPPORTED.indexOf(stored) !== -1) return stored;
        } catch(e) {}
        return 'zh';
      }

      function applyBlogLang(lang) {
        var strings = BLOG_STRINGS[lang];
        if (!strings) return;

        var catMap = CATEGORY_I18N[lang] || {};
        var diffMap = DIFFICULTY_I18N[lang] || {};

        // Filter posts and translate badges
        var items = document.querySelectorAll('.post-item');
        var count = 0;
        for (var i = 0; i < items.length; i++) {
          var postLang = items[i].getAttribute('data-post-lang');
          if (postLang === lang) {
            items[i].setAttribute('data-hidden', 'false');
            items[i].style.display = '';
            count++;

            // Translate category and difficulty badges
            var catBadge = items[i].querySelector('[data-translate="category"]');
            var diffBadge = items[i].querySelector('[data-translate="difficulty"]');
            var rawCat = items[i].getAttribute('data-category');
            var rawDiff = items[i].getAttribute('data-difficulty');
            if (catBadge && rawCat) catBadge.textContent = catMap[rawCat] || rawCat;
            if (diffBadge && rawDiff) diffBadge.textContent = diffMap[rawDiff] || rawDiff;
          } else {
            items[i].setAttribute('data-hidden', 'true');
            items[i].style.display = 'none';
          }
        }

        // Update title and subtitle
        var titleEl = document.getElementById('blog-title');
        var subtitleEl = document.getElementById('blog-subtitle');
        if (titleEl) titleEl.textContent = strings.title;
        if (subtitleEl) subtitleEl.textContent = strings.subtitle(count);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() { applyBlogLang(getLang()); });
      } else {
        applyBlogLang(getLang());
      }

      // Listen for storage changes (if user switches lang in another tab)
      window.addEventListener('storage', function(e) {
        if (e.key === 'site-lang') applyBlogLang(getLang());
      });
    })();
    </script>
  </body>
</html>
