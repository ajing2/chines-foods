---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  // 列表页只展示中文（默认语言）文章，译文版本通过文章内的语言切换器访问
  .filter((post) => !post.data.lang || post.data.lang === 'zh')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`食谱列表 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      .page-title {
        font-size: 2em;
        margin-bottom: 0.2em;
      }
      .page-subtitle {
        color: rgb(var(--gray));
        margin-bottom: 2em;
      }
      .posts-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      .post-item a {
        display: flex;
        gap: 1.2em;
        text-decoration: none;
        border-radius: 10px;
        border: 1px solid rgb(var(--gray-light));
        overflow: hidden;
        transition: box-shadow 0.2s;
      }
      .post-item a:hover {
        box-shadow: var(--box-shadow);
        text-decoration: none;
      }
      .post-item img {
        width: 180px;
        height: 120px;
        object-fit: cover;
        flex-shrink: 0;
        border-radius: 0;
      }
      .post-item .item-body {
        padding: 1em 1em 1em 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
      .item-meta {
        display: flex;
        gap: 0.6em;
        align-items: center;
        margin-bottom: 0.4em;
      }
      .category-badge {
        background: var(--accent);
        color: white;
        padding: 0.15em 0.6em;
        border-radius: 20px;
        font-size: 0.78em;
        font-weight: 600;
      }
      .difficulty-badge {
        border: 1px solid rgb(var(--gray-light));
        padding: 0.15em 0.6em;
        border-radius: 20px;
        font-size: 0.78em;
        color: rgb(var(--gray));
      }
      .post-item h2 {
        font-size: 1.15em;
        margin: 0 0 0.3em;
        color: rgb(var(--black));
      }
      .post-item p {
        font-size: 0.9em;
        color: rgb(var(--gray));
        margin: 0 0 0.4em;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .post-date {
        font-size: 0.82em;
        color: rgb(var(--gray));
      }
      @media (max-width: 600px) {
        .post-item img { width: 110px; height: 90px; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1 class="page-title">所有食谱</h1>
      <p class="page-subtitle">共 {posts.length} 道菜</p>
      <ul class="posts-list">
        {posts.map((post) => (
          <li class="post-item">
            <a href={`/blog/${post.id}/`}>
              {post.data.heroImage && (
                <img src={post.data.heroImage} alt={post.data.title} />
              )}
              <div class="item-body">
                <div class="item-meta">
                  <span class="category-badge">{post.data.category}</span>
                  <span class="difficulty-badge">{post.data.difficulty}</span>
                </div>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                <span class="post-date">
                  <FormattedDate date={post.data.pubDate} />
                  {post.data.cookTime && ` · 烹饪 ${post.data.cookTime}`}
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </main>
    <Footer />
  </body>
</html>
