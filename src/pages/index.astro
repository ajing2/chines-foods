---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

// 获取所有文章（所有语言），传给客户端做过滤
const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="zh-CN" id="html-root">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      /* ── Reset ── */
      body { background: #0a0a0a; color: #fff; margin: 0; }

      /* ── LANGUAGE SWITCHER (floating) ── */
      .lang-switcher {
        position: fixed;
        top: 1.2em;
        right: 1.5em;
        z-index: 1000;
        display: flex;
        gap: 0.3em;
        background: rgba(10,10,10,0.85);
        backdrop-filter: blur(16px) saturate(1.5);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 100px;
        padding: 0.35em 0.5em;
        box-shadow: 0 8px 32px rgba(0,0,0,0.5);
        animation: fade-in-down 0.6s ease 0.3s both;
      }
      .lang-btn {
        display: flex;
        align-items: center;
        gap: 0.3em;
        padding: 0.4em 0.75em;
        border-radius: 100px;
        font-size: 0.78em;
        font-weight: 600;
        color: rgba(255,255,255,0.5);
        cursor: pointer;
        border: none;
        background: transparent;
        transition: all 0.25s ease;
        white-space: nowrap;
      }
      .lang-btn:hover {
        color: #fff;
        background: rgba(255,255,255,0.08);
      }
      .lang-btn.active {
        color: #fff;
        background: linear-gradient(135deg, #c0392b, #e67e22);
        box-shadow: 0 2px 12px rgba(192,57,43,0.4);
        pointer-events: none;
      }
      .lang-flag { font-size: 1.1em; }

      /* ── HERO ── */
      .hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background: #0a0a0a;
      }

      /* Animated gradient orbs */
      .orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.55;
        animation: drift 12s ease-in-out infinite alternate;
        pointer-events: none;
      }
      .orb-1 {
        width: 600px; height: 600px;
        background: radial-gradient(circle, #c0392b 0%, transparent 70%);
        top: -150px; left: -150px;
      }
      .orb-2 {
        width: 500px; height: 500px;
        background: radial-gradient(circle, #e67e22 0%, transparent 70%);
        bottom: -100px; right: -100px;
        animation-delay: -4s;
      }
      .orb-3 {
        width: 350px; height: 350px;
        background: radial-gradient(circle, #8e44ad 0%, transparent 70%);
        top: 40%; left: 55%;
        animation-delay: -8s;
      }
      @keyframes drift {
        0%   { transform: translate(0, 0) scale(1); }
        50%  { transform: translate(40px, -30px) scale(1.08); }
        100% { transform: translate(-20px, 40px) scale(0.95); }
      }

      /* Floating particles */
      .particles { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
      .particle {
        position: absolute;
        width: 4px; height: 4px;
        background: rgba(255,255,255,0.6);
        border-radius: 50%;
        animation: float-up linear infinite;
      }
      @keyframes float-up {
        0%   { transform: translateY(100vh) scale(0); opacity: 0; }
        10%  { opacity: 1; }
        90%  { opacity: 0.6; }
        100% { transform: translateY(-10vh) scale(1.5); opacity: 0; }
      }

      /* Grid overlay */
      .grid-overlay {
        position: absolute; inset: 0;
        background-image:
          linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
        background-size: 60px 60px;
        pointer-events: none;
      }

      /* Hero content */
      .hero-content {
        position: relative; z-index: 10;
        text-align: center; padding: 2em; max-width: 900px;
      }

      .hero-badge {
        display: inline-flex; align-items: center; gap: 0.5em;
        background: rgba(192, 57, 43, 0.15);
        border: 1px solid rgba(192, 57, 43, 0.4);
        color: #e74c3c;
        padding: 0.4em 1.2em; border-radius: 100px;
        font-size: 0.85em; font-weight: 600;
        letter-spacing: 0.08em;
        margin-bottom: 1.5em;
        animation: fade-in-down 0.8s ease both;
      }
      .hero-badge::before {
        content: ''; width: 6px; height: 6px;
        background: #e74c3c; border-radius: 50%;
        animation: pulse-dot 1.5s ease-in-out infinite;
      }
      @keyframes pulse-dot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.4; transform: scale(0.6); }
      }

      .hero-title {
        font-size: clamp(3.2em, 9vw, 6.5em);
        font-weight: 900; line-height: 1.05;
        margin: 0 0 0.3em; letter-spacing: -0.02em;
        animation: fade-in-up 0.9s ease 0.2s both;
      }
      .hero-title .line-1 {
        display: block;
        background: linear-gradient(135deg, #fff 0%, rgba(255,255,255,0.7) 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .hero-title .line-2 {
        display: block;
        background: linear-gradient(135deg, #e74c3c 0%, #e67e22 50%, #f39c12 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text;
        filter: drop-shadow(0 0 30px rgba(231,76,60,0.5));
      }

      .hero-desc {
        font-size: clamp(1em, 2.5vw, 1.2em);
        color: rgba(255,255,255,0.55);
        max-width: 560px; margin: 0 auto 2.5em;
        line-height: 1.7;
        animation: fade-in-up 0.9s ease 0.4s both;
      }

      .hero-cta {
        display: flex; gap: 1em; justify-content: center; flex-wrap: wrap;
        animation: fade-in-up 0.9s ease 0.6s both;
      }
      .btn-primary {
        display: inline-flex; align-items: center; gap: 0.5em;
        background: linear-gradient(135deg, #c0392b, #e67e22);
        color: #fff; padding: 0.85em 2.2em; border-radius: 100px;
        font-weight: 700; font-size: 1em; text-decoration: none;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 24px rgba(192,57,43,0.4);
      }
      .btn-primary:hover {
        transform: translateY(-3px) scale(1.03);
        box-shadow: 0 8px 40px rgba(192,57,43,0.6);
        text-decoration: none;
      }
      .btn-secondary {
        display: inline-flex; align-items: center; gap: 0.5em;
        background: rgba(255,255,255,0.07);
        border: 1px solid rgba(255,255,255,0.15);
        color: rgba(255,255,255,0.85);
        padding: 0.85em 2.2em; border-radius: 100px;
        font-weight: 600; font-size: 1em; text-decoration: none;
        transition: background 0.2s, transform 0.2s;
        backdrop-filter: blur(10px);
      }
      .btn-secondary:hover {
        background: rgba(255,255,255,0.12);
        transform: translateY(-3px); text-decoration: none;
      }

      /* Scroll indicator */
      .scroll-hint {
        position: absolute; bottom: 2.5em; left: 50%;
        transform: translateX(-50%);
        display: flex; flex-direction: column; align-items: center; gap: 0.5em;
        color: rgba(255,255,255,0.3); font-size: 0.75em;
        letter-spacing: 0.1em; text-transform: uppercase;
        animation: fade-in 1s ease 1.2s both; z-index: 10;
      }
      .scroll-line {
        width: 1px; height: 50px;
        background: linear-gradient(to bottom, rgba(255,255,255,0.4), transparent);
        animation: scroll-pulse 2s ease-in-out infinite;
      }
      @keyframes scroll-pulse {
        0%, 100% { transform: scaleY(1); opacity: 0.4; }
        50% { transform: scaleY(0.6); opacity: 1; }
      }

      /* ── STATS BAR ── */
      .stats-bar {
        background: rgba(255,255,255,0.03);
        border-top: 1px solid rgba(255,255,255,0.06);
        border-bottom: 1px solid rgba(255,255,255,0.06);
        padding: 2em 0;
      }
      .stats-inner {
        max-width: 900px; margin: 0 auto; padding: 0 2em;
        display: flex; justify-content: center; gap: 4em; flex-wrap: wrap;
      }
      .stat-item { text-align: center; }
      .stat-num {
        font-size: 2.5em; font-weight: 900;
        background: linear-gradient(135deg, #e74c3c, #e67e22);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text; line-height: 1;
      }
      .stat-label {
        font-size: 0.82em; color: rgba(255,255,255,0.4);
        margin-top: 0.3em; letter-spacing: 0.05em;
      }

      /* ── LANGUAGE SHOWCASE ── */
      .lang-showcase {
        padding: 5em 2em;
        background: linear-gradient(180deg, rgba(192,57,43,0.06) 0%, transparent 100%);
        border-top: 1px solid rgba(255,255,255,0.06);
      }
      .lang-showcase-inner {
        max-width: 1000px; margin: 0 auto; text-align: center;
      }
      .lang-showcase-title {
        font-size: clamp(1.5em, 3.5vw, 2.2em); font-weight: 800;
        color: #fff; margin-bottom: 0.5em;
      }
      .lang-showcase-desc {
        color: rgba(255,255,255,0.4); margin-bottom: 3em; font-size: 1em;
      }
      .lang-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 1em;
      }
      .lang-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px; padding: 1.5em 1em;
        transition: all 0.3s ease; cursor: pointer;
      }
      .lang-card:hover {
        background: rgba(192,57,43,0.1);
        border-color: rgba(192,57,43,0.4);
        transform: translateY(-4px);
      }
      .lang-card.active {
        background: rgba(192,57,43,0.15);
        border-color: rgba(192,57,43,0.5);
        box-shadow: 0 4px 20px rgba(192,57,43,0.2);
      }
      .lang-card-flag { font-size: 2.5em; margin-bottom: 0.3em; display: block; }
      .lang-card-name { font-size: 1em; font-weight: 700; color: #fff; display: block; }
      .lang-card-native {
        font-size: 0.8em; color: rgba(255,255,255,0.4); margin-top: 0.2em; display: block;
      }

      /* ── SECTION ── */
      .section { max-width: 1200px; margin: 0 auto; padding: 6em 2em; }
      .section-header {
        display: flex; align-items: flex-end; justify-content: space-between;
        margin-bottom: 3em; flex-wrap: wrap; gap: 1em;
      }
      .section-label {
        font-size: 0.78em; font-weight: 700; letter-spacing: 0.15em;
        text-transform: uppercase; color: #e74c3c; margin-bottom: 0.5em;
      }
      .section-title {
        font-size: clamp(1.8em, 4vw, 2.8em); font-weight: 900;
        color: #fff; margin: 0; line-height: 1.1;
      }
      .section-link {
        color: rgba(255,255,255,0.4); font-size: 0.9em; text-decoration: none;
        display: flex; align-items: center; gap: 0.4em;
        transition: color 0.2s; white-space: nowrap;
      }
      .section-link:hover { color: #e74c3c; text-decoration: none; }
      .section-link::after { content: '\2192'; }

      /* ── RECIPE CARDS ── */
      .cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5em;
      }
      .recipe-card {
        position: relative; border-radius: 20px; overflow: hidden;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.35s;
        cursor: pointer; text-decoration: none; display: block;
      }
      .recipe-card[data-hidden="true"] { display: none; }
      .recipe-card:hover {
        transform: translateY(-8px) scale(1.01);
        box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(231,76,60,0.3);
        text-decoration: none;
      }
      .recipe-card::before {
        content: ''; position: absolute; inset: 0;
        background: linear-gradient(135deg, rgba(255,255,255,0.06) 0%, transparent 50%);
        pointer-events: none; z-index: 1; border-radius: 20px;
        opacity: 0; transition: opacity 0.3s;
      }
      .recipe-card:hover::before { opacity: 1; }

      .card-img-wrap { position: relative; height: 240px; overflow: hidden; }
      .card-img-wrap img {
        width: 100%; height: 100%; object-fit: cover;
        transition: transform 0.5s ease;
      }
      .recipe-card:hover .card-img-wrap img { transform: scale(1.08); }
      .card-img-overlay {
        position: absolute; inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.1) 60%, transparent 100%);
      }

      .card-tags {
        position: absolute; top: 1em; left: 1em;
        display: flex; gap: 0.4em; flex-wrap: wrap;
      }
      .tag {
        background: rgba(0,0,0,0.55); backdrop-filter: blur(8px);
        border: 1px solid rgba(255,255,255,0.15);
        color: rgba(255,255,255,0.85);
        padding: 0.2em 0.7em; border-radius: 100px;
        font-size: 0.72em; font-weight: 600;
      }
      .tag-hot { background: rgba(192,57,43,0.7); border-color: rgba(231,76,60,0.5); color: #fff; }
      .tag-lang { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.25); }

      .card-body { padding: 1.4em 1.5em 1.5em; }
      .card-title {
        font-size: 1.3em; font-weight: 800; color: #fff;
        margin: 0 0 0.5em; line-height: 1.3;
      }
      .card-desc {
        font-size: 0.88em; color: rgba(255,255,255,0.45);
        line-height: 1.6; margin: 0 0 1.2em;
        display: -webkit-box; -webkit-line-clamp: 2;
        -webkit-box-orient: vertical; overflow: hidden;
      }
      .card-meta { display: flex; gap: 1.2em; align-items: center; }
      .meta-item {
        display: flex; align-items: center; gap: 0.35em;
        font-size: 0.8em; color: rgba(255,255,255,0.35);
      }

      /* ── FEATURE STRIP ── */
      .feature-strip {
        background: linear-gradient(135deg, rgba(192,57,43,0.12) 0%, rgba(230,126,34,0.08) 100%);
        border-top: 1px solid rgba(192,57,43,0.2);
        border-bottom: 1px solid rgba(192,57,43,0.2);
        padding: 4em 2em;
      }
      .feature-inner {
        max-width: 1000px; margin: 0 auto;
        display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 2.5em;
      }
      .feature-item { text-align: center; }
      .feature-icon {
        font-size: 2.5em; margin-bottom: 0.5em; display: block;
        filter: drop-shadow(0 0 12px rgba(231,76,60,0.4));
      }
      .feature-title { font-size: 1.05em; font-weight: 700; color: #fff; margin-bottom: 0.4em; }
      .feature-desc { font-size: 0.85em; color: rgba(255,255,255,0.4); line-height: 1.6; }

      /* ── FOOTER ── */
      .page-footer {
        background: #0a0a0a;
        border-top: 1px solid rgba(255,255,255,0.06);
      }

      /* ── ANIMATIONS ── */
      @keyframes fade-in-up {
        from { opacity: 0; transform: translateY(30px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes fade-in-down {
        from { opacity: 0; transform: translateY(-20px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes fade-in {
        from { opacity: 0; }
        to   { opacity: 1; }
      }

      .reveal {
        opacity: 0; transform: translateY(40px);
        transition: opacity 0.7s ease, transform 0.7s ease;
      }
      .reveal.visible { opacity: 1; transform: translateY(0); }
      .reveal-delay-1 { transition-delay: 0.1s; }
      .reveal-delay-2 { transition-delay: 0.2s; }
      .reveal-delay-3 { transition-delay: 0.3s; }

      /* ── RESPONSIVE ── */
      @media (max-width: 768px) {
        .stats-inner { gap: 2em; }
        .section { padding: 4em 1.2em; }
        .cards-grid { grid-template-columns: 1fr; }
        .hero-cta { flex-direction: column; align-items: center; }
        .lang-switcher {
          top: auto; bottom: 1em; right: 50%;
          transform: translateX(50%);
        }
      }
    </style>
  </head>
  <body>

    <!-- ── LANGUAGE SWITCHER (floating top-right) ── -->
    <nav class="lang-switcher" id="lang-switcher" aria-label="Language selector">
      <button class="lang-btn" data-lang="zh"><span class="lang-flag">&#x1F1E8;&#x1F1F3;</span> 中文</button>
      <button class="lang-btn" data-lang="en"><span class="lang-flag">&#x1F1FA;&#x1F1F8;</span> EN</button>
      <button class="lang-btn" data-lang="ja"><span class="lang-flag">&#x1F1EF;&#x1F1F5;</span> JA</button>
      <button class="lang-btn" data-lang="fr"><span class="lang-flag">&#x1F1EB;&#x1F1F7;</span> FR</button>
      <button class="lang-btn" data-lang="de"><span class="lang-flag">&#x1F1E9;&#x1F1EA;</span> DE</button>
    </nav>

    <!-- ── HERO ── -->
    <section class="hero">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
      <div class="grid-overlay"></div>
      <div class="particles" id="particles"></div>

      <div class="hero-content">
        <div class="hero-badge" data-i18n="heroBadge"></div>

        <h1 class="hero-title">
          <span class="line-1" data-i18n="heroLine1"></span>
          <span class="line-2" data-i18n="heroLine2"></span>
        </h1>

        <p class="hero-desc" data-i18n-html="heroDesc"></p>

        <div class="hero-cta">
          <a href="/blog" class="btn-primary" data-i18n="heroCta1"></a>
          <a href="/blog/kung-pao-chicken-zh/" class="btn-secondary" id="hero-recommend" data-i18n="heroCta2"></a>
        </div>
      </div>

      <div class="scroll-hint">
        <span data-i18n="scrollHint"></span>
        <div class="scroll-line"></div>
      </div>
    </section>

    <!-- ── STATS ── -->
    <div class="stats-bar">
      <div class="stats-inner">
        <div class="stat-item">
          <div class="stat-num" id="stat-recipe-count">1</div>
          <div class="stat-label" data-i18n="statRecipes"></div>
        </div>
        <div class="stat-item">
          <div class="stat-num">5</div>
          <div class="stat-label" data-i18n="statLangs"></div>
        </div>
        <div class="stat-item">
          <div class="stat-num">4K</div>
          <div class="stat-label" data-i18n="statPhotos"></div>
        </div>
        <div class="stat-item">
          <div class="stat-num">100%</div>
          <div class="stat-label" data-i18n="statHomemade"></div>
        </div>
      </div>
    </div>

    <!-- ── LANGUAGE SHOWCASE ── -->
    <section class="lang-showcase reveal">
      <div class="lang-showcase-inner">
        <h2 class="lang-showcase-title" data-i18n="feat2Title"></h2>
        <p class="lang-showcase-desc" data-i18n="feat2Desc"></p>
        <div class="lang-cards" id="lang-cards">
          <div class="lang-card" data-lang="zh">
            <span class="lang-card-flag">&#x1F1E8;&#x1F1F3;</span>
            <span class="lang-card-name">中文</span>
            <span class="lang-card-native">Simplified Chinese</span>
          </div>
          <div class="lang-card" data-lang="en">
            <span class="lang-card-flag">&#x1F1FA;&#x1F1F8;</span>
            <span class="lang-card-name">English</span>
            <span class="lang-card-native">英语</span>
          </div>
          <div class="lang-card" data-lang="ja">
            <span class="lang-card-flag">&#x1F1EF;&#x1F1F5;</span>
            <span class="lang-card-name">日本語</span>
            <span class="lang-card-native">Japanese</span>
          </div>
          <div class="lang-card" data-lang="fr">
            <span class="lang-card-flag">&#x1F1EB;&#x1F1F7;</span>
            <span class="lang-card-name">Fran&#231;ais</span>
            <span class="lang-card-native">French</span>
          </div>
          <div class="lang-card" data-lang="de">
            <span class="lang-card-flag">&#x1F1E9;&#x1F1EA;</span>
            <span class="lang-card-name">Deutsch</span>
            <span class="lang-card-native">German</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── RECIPES ── -->
    <section class="section">
      <div class="section-header reveal">
        <div>
          <div class="section-label" data-i18n="sectionLabel"></div>
          <h2 class="section-title" data-i18n="sectionTitle"></h2>
        </div>
        <a href="/blog" class="section-link" data-i18n="sectionLink"></a>
      </div>

      <div class="cards-grid" id="cards-grid">
        {allPosts.map((post, i) => (
          <a
            href={`/blog/${post.id}/`}
            class={`recipe-card reveal reveal-delay-${(i % 3) + 1}`}
            data-card-lang={post.data.lang || 'zh'}
            data-hidden="true"
          >
            <div class="card-img-wrap">
              {post.data.heroImage && (
                <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
              )}
              <div class="card-img-overlay"></div>
              <div class="card-tags">
                <span class="tag tag-hot">&#x1F525;</span>
                <span class="tag tag-lang">{
                  (post.data.lang || 'zh') === 'zh' ? '\u{1F1E8}\u{1F1F3}' :
                  (post.data.lang || 'zh') === 'en' ? '\u{1F1FA}\u{1F1F8}' :
                  (post.data.lang || 'zh') === 'ja' ? '\u{1F1EF}\u{1F1F5}' :
                  (post.data.lang || 'zh') === 'fr' ? '\u{1F1EB}\u{1F1F7}' :
