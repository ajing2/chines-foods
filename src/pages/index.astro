---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  // 首页只展示中文（默认语言）文章，避免译文重复出现
  .filter((post) => !post.data.lang || post.data.lang === 'zh')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6); // 首页展示最新 6 篇
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .hero {
        text-align: center;
        padding: 3em 1em 2em;
      }
      .hero h1 {
        font-size: 3em;
        color: var(--accent);
        margin-bottom: 0.3em;
      }
      .hero p {
        font-size: 1.1em;
        color: rgb(var(--gray));
        max-width: 500px;
        margin: 0 auto 1.5em;
      }
      .hero a.cta {
        display: inline-block;
        background: var(--accent);
        color: white;
        padding: 0.7em 2em;
        border-radius: 6px;
        font-weight: 600;
        text-decoration: none;
        transition: background 0.2s;
      }
      .hero a.cta:hover {
        background: var(--accent-dark);
        text-decoration: none;
      }
      .section-title {
        font-size: 1.5em;
        font-weight: 700;
        margin: 2em 0 1em;
        padding-bottom: 0.4em;
        border-bottom: 2px solid rgb(var(--gray-light));
      }
      .posts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .post-card a {
        display: block;
        text-decoration: none;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid rgb(var(--gray-light));
        transition: box-shadow 0.2s, transform 0.2s;
      }
      .post-card a:hover {
        box-shadow: var(--box-shadow);
        transform: translateY(-2px);
        text-decoration: none;
      }
      .post-card img {
        width: 100%;
        height: 180px;
        object-fit: cover;
        border-radius: 0;
        display: block;
      }
      .post-card .card-body {
        padding: 1em;
      }
      .post-card .card-category {
        font-size: 0.75em;
        color: var(--accent);
        font-weight: 600;
        text-transform: uppercase;
        margin-bottom: 0.3em;
      }
      .post-card h3 {
        font-size: 1.05em;
        margin: 0 0 0.4em;
        color: rgb(var(--black));
        line-height: 1.4;
      }
      .post-card .card-date {
        font-size: 0.82em;
        color: rgb(var(--gray));
      }
      .view-all {
        text-align: center;
        margin-top: 2em;
      }
      .view-all a {
        color: var(--accent);
        font-weight: 600;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="hero">
        <h1>🍜 中餐食谱</h1>
        <p>{SITE_DESCRIPTION}</p>
        <a class="cta" href="/blog">浏览所有食谱</a>
      </div>

      {posts.length > 0 && (
        <>
          <h2 class="section-title">最新食谱</h2>
          <ul class="posts-grid">
            {posts.map((post) => (
              <li class="post-card">
                <a href={`/blog/${post.id}/`}>
                  {post.data.heroImage && (
                    <img src={post.data.heroImage} alt={post.data.title} />
                  )}
                  <div class="card-body">
                    <div class="card-category">{post.data.category}</div>
                    <h3>{post.data.title}</h3>
                    <div class="card-date">
                      <FormattedDate date={post.data.pubDate} />
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
          <div class="view-all">
            <a href="/blog">查看全部食谱 →</a>
          </div>
        </>
      )}
    </main>
    <Footer />
  </body>
</html>
