        var SUPPORTED = ['zh', 'en', 'ja', 'fr', 'de'];

        function getLang() {
          try {
            var stored = localStorage.getItem('site-lang');
            if (stored && SUPPORTED.indexOf(stored) !== -1) return stored;
          } catch(e) {}
          return 'zh';
        }

        function applyLang(lang) {
          var strings = UI[lang];
          if (!strings) return;

          // Update text content
          var els = document.querySelectorAll('[data-i18n]');
          for (var i = 0; i < els.length; i++) {
            var key = els[i].getAttribute('data-i18n');
            if (strings[key] !== undefined) {
              els[i].textContent = strings[key];
            }
          }

          // Update HTML content (for line breaks)
          var htmlEls = document.querySelectorAll('[data-i18n-html]');
          for (var i = 0; i < htmlEls.length; i++) {
            var key = htmlEls[i].getAttribute('data-i18n-html');
            if (strings[key] !== undefined) {
              htmlEls[i].innerHTML = strings[key];
            }
          }

          // Update html lang
          document.documentElement.lang = lang === 'zh' ? 'zh-CN' : lang;

          // Update switcher buttons
          var btns = document.querySelectorAll('.lang-btn');
          for (var i = 0; i < btns.length; i++) {
            if (btns[i].getAttribute('data-lang') === lang) {
              btns[i].classList.add('active');
            } else {
              btns[i].classList.remove('active');
            }
          }

          // Update lang cards
          var cards = document.querySelectorAll('.lang-card');
          for (var i = 0; i < cards.length; i++) {
            if (cards[i].getAttribute('data-lang') === lang) {
              cards[i].classList.add('active');
            } else {
              cards[i].classList.remove('active');
            }
          }

          // Filter recipe cards
          var recipeCards = document.querySelectorAll('.recipe-card');
          for (var i = 0; i < recipeCards.length; i++) {
            var cardLang = recipeCards[i].getAttribute('data-card-lang');
            if (cardLang === lang) {
              recipeCards[i].setAttribute('data-hidden', 'false');
              recipeCards[i].style.display = '';
              // Force visible (scroll-reveal won't fire for initially hidden cards)
              recipeCards[i].classList.add('visible');
            } else {
              recipeCards[i].setAttribute('data-hidden', 'true');
              recipeCards[i].style.display = 'none';
            }
          }

          // Update recommend link
          var recommendBtn = document.getElementById('hero-recommend');
          if (recommendBtn && strings.recommendSlug) {
            recommendBtn.setAttribute('href', '/blog/' + strings.recommendSlug + '/');
          }
        }

        // Expose to window so Header's lang switcher can call it
        window.applyLang = applyLang;

        function setLang(lang) {
          try { localStorage.setItem('site-lang', lang); } catch(e) {}
          applyLang(lang);
        }

        // Apply immediately (before DOMContentLoaded for faster render)
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function() {
            applyLang(getLang());
          });
        } else {
          applyLang(getLang());
        }

        // Bind switcher clicks
        document.addEventListener('DOMContentLoaded', function() {
          applyLang(getLang());

          // Top switcher
          var btns = document.querySelectorAll('.lang-btn');
          for (var i = 0; i < btns.length; i++) {
            btns[i].addEventListener('click', function() {
              setLang(this.getAttribute('data-lang'));
            });
          }

          // Lang cards also switch
          var langCards = document.querySelectorAll('.lang-card');
          for (var i = 0; i < langCards.length; i++) {
            langCards[i].addEventListener('click', function() {
              setLang(this.getAttribute('data-lang'));
              // Scroll to recipe section so user can see the change
              var cardsGrid = document.getElementById('cards-grid');
              if (cardsGrid) {
                cardsGrid.scrollIntoView({ behavior: 'smooth', block: 'center' });
              }
            });
          }
        });

        // ── Floating particles ──
        document.addEventListener('DOMContentLoaded', function() {
          var container = document.getElementById('particles');
          if (container) {
            for (var i = 0; i < 30; i++) {
              var p = document.createElement('div');
              p.className = 'particle';
              p.style.left = (Math.random() * 100) + '%';
              p.style.width = (2 + Math.random() * 4) + 'px';
              p.style.height = p.style.width;
              p.style.animationDuration = (6 + Math.random() * 10) + 's';
              p.style.animationDelay = (Math.random() * 10) + 's';
              p.style.opacity = String(0.3 + Math.random() * 0.5);
              container.appendChild(p);
            }
          }

          // ── Scroll reveal ──
          var observer = new IntersectionObserver(
            function(entries) {
              entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                  entry.target.classList.add('visible');
                }
              });
            },
            { threshold: 0.12 }
          );
          var revealEls = document.querySelectorAll('.reveal');
          for (var i = 0; i < revealEls.length; i++) {
            observer.observe(revealEls[i]);
          }
        });

        // ── Parallax orbs on mouse move ──
        document.addEventListener('mousemove', function(e) {
          var x = (e.clientX / window.innerWidth - 0.5) * 20;
          var y = (e.clientY / window.innerHeight - 0.5) * 20;
          var orbs = document.querySelectorAll('.orb');
          for (var i = 0; i < orbs.length; i++) {
            var factor = (i + 1) * 0.4;
            orbs[i].style.transform = 'translate(' + (x * factor) + 'px, ' + (y * factor) + 'px)';
          }
        });
      })();
